# Neon Postgres — provisioned via Vercel marketplace integration
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# Cron protection — random secret; Vercel Cron sends as ?secret=<value>
CRON_SECRET="generate-with-openssl-rand-hex-32"

# Polite scraper identity
SCRAPER_USER_AGENT="GridironExchange/0.1 (+https://github.com/m1kxbu/fantasy-app)"
