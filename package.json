{
  "name": "gridiron-exchange",
  "version": "0.1.0",
  "private": true,
  "description": "Fantasy football ADP, traded like stock — real movement from daily snapshots.",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node --env-file-if-exists=.env.local --import tsx src/db/migrate.ts",
    "seed:demo": "node --env-file-if-exists=.env.local --import tsx scripts/seed-demo-history.ts"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@neondatabase/serverless": "1.1.0",
    "drizzle-orm": "0.45.2",
    "cheerio": "1.2.0",
    "d3-force": "3.0.0",
    "d3-hierarchy": "3.1.2",
    "lucide-react": "1.17.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/d3-force": "3.0.10",
    "@types/d3-hierarchy": "3.1.7",
    "tailwindcss": "4.3.0",
    "@tailwindcss/postcss": "4.3.0",
    "vitest": "4.1.7",
    "@vitejs/plugin-react": "6.0.2",
    "tsx": "4.20.6"
  },
  "overrides": {
    "esbuild": ">=0.25.4",
    "postcss": "^8.5.15"
  }
}
